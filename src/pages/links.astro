---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import IconLinkedin from "../components/icons/linkedin.astro";
import CoffeeChatButton from "../components/CoffeeChatButton";
import SocialLinks from "../components/SocialLinks.astro";
import { Image } from "astro:assets";
import profileImage from "../../public/profile.png";
import rmLogo from "../../public/logos/rcmcodes_white.svg";
import BrandLogo from "../components/BrandLogo.astro";
import { PROFILE } from "../data/profile";
import { LINK_LABELS, LINK_ROW_CLASS, LINK_ICON_CLASS } from "../data/contact";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Links" },
];
---

<Layout
  title={`Links - connect with ${PROFILE.displayName}`}
  seo={{
    description: `Connect with ${PROFILE.displayName} | ${PROFILE.title}. ${PROFILE.focus}`,
    canonical: "https://rcmcodes.com/links",
    openGraph: {
      title: `Connect with ${PROFILE.displayName} - ${PROFILE.title}`,
      description:
        "Find all my professional links and ways to connect. Portfolio, LinkedIn, and partnership opportunities available.",
      type: "profile",
    },
    structuredData: {
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      mainEntity: {
        "@type": "Person",
        name: PROFILE.displayName,
        alternateName: [PROFILE.alternateName, "rcmcodes"],
        jobTitle: PROFILE.title,
        url: "https://rcmcodes.com",
        image: `https://rcmcodes.com${PROFILE.imagePath}`,
        sameAs: [
          "https://www.linkedin.com/in/rcmcodes/",
          "https://rcmcodes.com",
        ],
      },
    },
  }}
>
  <div class="links-hub relative z-10 min-h-screen font-sans">
    <div
      class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-6 py-16"
    >
      <Breadcrumbs items={breadcrumbItems} class="w-full" />

      <header class="mb-8 text-center">
        <Image
          src={profileImage}
          alt={PROFILE.imageAlt}
          class="mx-auto h-24 w-24 rounded-xl object-cover ring-2 ring-neutral-700/80 pixelated"
          width={192}
          height={192}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />

        <h1
          class="mt-6 inline-block rounded-full bg-neutral-400/10 px-3 py-1 text-sm font-medium text-neutral-200/80"
        >
          Connect with {PROFILE.displayName}
        </h1>

        <p class="mt-3 text-sm text-neutral-400">{PROFILE.title}</p>
        <p class="mt-2 px-2 text-xs leading-relaxed text-neutral-500">
          {PROFILE.focus}
        </p>
      </header>

      <div
        class="mb-8 rounded-xl border border-neutral-700/60 bg-neutral-400/10 p-4 shadow backdrop-blur-xl"
      >
        <p class="text-sm leading-relaxed text-neutral-300">
          {PROFILE.intro}
        </p>
      </div>

      <nav class="mb-10 space-y-3" aria-label="Professional links">
        <a
          href="https://rcmcodes.com"
          target="_blank"
          rel="noopener noreferrer"
          class={LINK_ROW_CLASS}
        >
          <span class={LINK_ICON_CLASS}>
            <Image
              src={rmLogo}
              alt=""
              class="h-5 w-5 object-contain"
              width={20}
              height={20}
              aria-hidden="true"
            />
          </span>
          <span>{LINK_LABELS.portfolio}</span>
        </a>

        <a href="/partner/" class={LINK_ROW_CLASS}>
          <span class={LINK_ICON_CLASS}>
            <BrandLogo variant="icon" />
          </span>
          <span>{LINK_LABELS.partner}</span>
        </a>

        <CoffeeChatButton client:load />

        <a
          href="https://www.linkedin.com/in/rcmcodes/"
          target="_blank"
          rel="noopener noreferrer"
          class={LINK_ROW_CLASS}
          aria-label="Connect on LinkedIn (opens in a new tab)"
        >
          <span class={LINK_ICON_CLASS}>
            <IconLinkedin />
          </span>
          <span>{LINK_LABELS.linkedIn}</span>
        </a>
      </nav>

      <footer class="border-t border-neutral-800/60 pt-8 text-center">
        <SocialLinks />
        <p class="mt-6">
          <a
            href="/"
            class="text-sm font-medium text-neutral-400 transition-colors hover:text-neutral-100 focus-visible:text-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-500/50"
          >
            {LINK_LABELS.backHome}
          </a>
        </p>
        <p class="mt-4 text-xs text-neutral-500">
          {new Date().getFullYear()}. All rights reserved.
        </p>
      </footer>
    </div>
  </div>
</Layout>

<style>
  .links-hub {
    background-image: url(/pattern.svg);
    background-position: top center;
    background-repeat: no-repeat;
  }
</style>
