---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrandLogo from "../components/BrandLogo.astro";
import { Image } from "astro:assets";
import profileImage from "../../public/profile.png";
import { BRAND } from "../data/brand";
import { PROFILE } from "../data/profile";
import { PARTNER_EXPECTATIONS, TEAM } from "../data/team";
import {
  GLASS_CARD_CLASS,
  GLASS_INPUT_CLASS,
  GLASS_BTN_PRIMARY_CLASS,
} from "../data/contact";
const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Partner" },
];
---

<Layout
  title={`${BRAND.studioName} | Custom Software & Web Development`}
  seo={{
    description:
      "Twin Rocks Software Studio builds custom software and professional websites for small and medium businesses. Websites from $500+, custom software from $5,000+. Led by Roberto M., full-stack engineer focused on SMB websites, operations tools, and workflow automation.",
    canonical: "https://rcmcodes.com/partner",
    keywords:
      "Twin Rocks Software Studio, custom software development, web development, full stack developer, small business software, Roberto Murillo",
    openGraph: {
      title: `${BRAND.studioName}: Software & Web Development`,
      description:
        "Custom software and websites for businesses that have outgrown spreadsheets and manual workflows. Transparent pricing and production-ready engineering for small and medium teams.",
      type: "website",
    },
    structuredData: {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      name: BRAND.studioName,
      description:
        "Custom software development and web creation for small and medium businesses.",
      url: "https://rcmcodes.com/partner",
      image: `https://rcmcodes.com${BRAND.logoRasterPath}`,
      founder: {
        "@type": "Person",
        name: PROFILE.displayName,
        jobTitle: PROFILE.title,
        url: "https://rcmcodes.com",
      },
      serviceType: ["Software Development", "Web Development", "Internal Tooling"],
      areaServed: "Worldwide",
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Development Services",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Custom Software",
              description:
                "Full-stack applications, internal tools, and workflow automation",
            },
            priceSpecification: {
              "@type": "PriceSpecification",
              minPrice: "5000",
              priceCurrency: "USD",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Website Development",
              description: "Professional, responsive websites built to convert",
            },
            priceSpecification: {
              "@type": "PriceSpecification",
              minPrice: "500",
              priceCurrency: "USD",
            },
          },
        ],
      },
    },
  }}
>
  <div class="partner-page relative z-10">
    <div
      class="mx-auto max-w-screen-2xl px-6 py-12 font-sans md:px-12 md:py-16 lg:px-24"
    >
      <Breadcrumbs items={breadcrumbItems} />

      <!-- Hero -->
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-3xl">
          <div
            class="flex flex-col items-center gap-6 text-center md:flex-row md:items-center md:gap-10 md:text-left"
          >
            <BrandLogo
              variant="hero"
              class="ring-2 ring-neutral-700/80"
              loading="eager"
            />
            <div class="min-w-0 flex-1">
              <p
                class="inline-block rounded-full border border-neutral-700/60 bg-neutral-400/10 px-3 py-1 text-sm font-medium text-neutral-300 backdrop-blur-xl"
              >
                {BRAND.studioName}
              </p>
              <h1
                class="mt-4 text-4xl font-bold tracking-tight text-neutral-100 md:text-5xl lg:text-6xl"
              >
                Software & websites for teams ready to move past spreadsheets
              </h1>
              <p class="mt-6 text-lg leading-relaxed text-neutral-300 md:text-xl">
                {BRAND.studioName} is a development studio for small and medium
                businesses. Led by {PROFILE.displayName}, a {PROFILE.title.toLowerCase()}
                who helps teams replace spreadsheets and manual processes with
                websites, custom software, quoting tools, and lead-generation
                platforms your staff can rely on every day.
              </p>
              <div class="mt-10 flex flex-wrap justify-center gap-4 md:justify-start">
                <a href="#partner-form" class={GLASS_BTN_PRIMARY_CLASS}>
                  Start a project conversation
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Pricing -->
      <section class="py-16 md:py-20" aria-labelledby="pricing-heading">
        <div class="mx-auto max-w-3xl text-center">
          <h2
            id="pricing-heading"
            class="text-3xl font-bold text-neutral-100 md:text-4xl"
          >
            Transparent starting points
          </h2>
          <p class="mt-4 text-lg text-neutral-400">
            Every engagement is scoped to your workflow. These ranges reflect
            typical project floors, not one-size packages.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          <article class={`${GLASS_CARD_CLASS} p-8 transition-all hover:border-neutral-500/60 hover:bg-neutral-400/15`}>
            <h3 class="text-xl font-semibold text-neutral-100">Websites</h3>
            <p class="mt-2 text-3xl font-bold text-neutral-100">
              from $500<span class="text-lg font-normal text-neutral-400">+</span>
            </p>
            <p class="mt-4 text-neutral-300 leading-relaxed">
              Marketing sites, landing pages, and content-driven properties built
              for trust, discoverability, and inbound inquiries.
            </p>
            <ul class="mt-6 space-y-2 text-sm text-neutral-300">
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                Responsive, performance-minded builds
              </li>
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                SEO and analytics foundations
              </li>
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                Astro, Next.js, or stack matched to scope
              </li>
            </ul>
          </article>

          <article class={`${GLASS_CARD_CLASS} p-8 transition-all hover:border-neutral-500/60 hover:bg-neutral-400/15`}>
            <h3 class="text-xl font-semibold text-neutral-100">Custom software</h3>
            <p class="mt-2 text-3xl font-bold text-neutral-100">
              from $5,000<span class="text-lg font-normal text-neutral-400">+</span>
            </p>
            <p class="mt-4 text-neutral-300 leading-relaxed">
              Full-stack applications, internal dashboards, quoting engines, and
              workflow automation tailored to how your team actually operates.
            </p>
            <ul class="mt-6 space-y-2 text-sm text-neutral-300">
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                TypeScript, React, Next.js, PostgreSQL
              </li>
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                API design and data modeling
              </li>
              <li class="flex gap-2">
                <span class="text-neutral-500" aria-hidden="true">•</span>
                Production deployment and handoff docs
              </li>
            </ul>
          </article>
        </div>
      </section>

      <!-- What you get -->
      <section class="py-12 md:py-16">
        <div class="grid gap-6 md:grid-cols-3">
          {
            [
              {
                title: "Scoped before code",
                body: "Discovery, requirements, and a clear proposal with timeline and deliverables, with no surprise invoices.",
              },
              {
                title: "Production discipline",
                body: "The same rigor applied on production business systems: typed code, documented handoffs, and maintainable architecture.",
              },
              {
                title: "Ongoing partnership",
                body: "Post-launch support and iteration as your workflow evolves, not a throw-it-over-the-wall delivery.",
              },
            ].map((item) => (
              <div
                class={`${GLASS_CARD_CLASS} p-6 transition-all hover:border-neutral-500/60 hover:bg-neutral-400/15`}
              >
                <h3 class="font-semibold text-neutral-100">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-400">
                  {item.body}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Form -->
      <section id="partner-form" class="py-16 md:py-20">
        <div class="grid items-start gap-12 lg:grid-cols-2">
          <div>
            <h2 class="text-3xl font-bold text-neutral-100 md:text-4xl">
              Tell us about your project
            </h2>
            <p class="mt-4 text-lg text-neutral-400">
              Share a few details and we'll respond within 24–72 hours with next
              steps.
            </p>

            <form
              class="mt-10 space-y-6"
              method="POST"
              name="partner-inquiry"
              action="/partner/success/"
              data-netlify="true"
              netlify-honeypot="bot-field"
            >
              <div style="display: none;">
                <label
                  >Don't fill this out if you're human: <input
                    name="bot-field"
                  /></label
                >
              </div>

              <fieldset class="space-y-3">
                <legend class="block text-sm font-semibold text-neutral-200">
                  Project type
                </legend>
                <div class="grid gap-3">
                  <label
                    class={`${GLASS_CARD_CLASS} flex cursor-pointer items-start gap-3 p-4 transition-all hover:border-neutral-500/60 hover:bg-neutral-400/15 has-[:checked]:border-neutral-500/60 has-[:checked]:bg-neutral-400/15`}
                  >
                    <input
                      type="radio"
                      name="project_type"
                      value="software"
                      class="mt-1 h-4 w-4 border-neutral-600 bg-transparent text-neutral-300 focus:ring-neutral-500/50"
                    />
                    <div>
                      <span class="font-medium text-neutral-100"
                        >Custom software</span
                      >
                      <p class="mt-1 text-sm text-neutral-400">
                        Applications, dashboards, automation, from $5,000+
                      </p>
                    </div>
                  </label>
                  <label
                    class={`${GLASS_CARD_CLASS} flex cursor-pointer items-start gap-3 p-4 transition-all hover:border-neutral-500/60 hover:bg-neutral-400/15 has-[:checked]:border-neutral-500/60 has-[:checked]:bg-neutral-400/15`}
                  >
                    <input
                      type="radio"
                      name="project_type"
                      value="website"
                      class="mt-1 h-4 w-4 border-neutral-600 bg-transparent text-neutral-300 focus:ring-neutral-500/50"
                    />
                    <div>
                      <span class="font-medium text-neutral-100">Website</span>
                      <p class="mt-1 text-sm text-neutral-400">
                        Marketing sites and web presence, from $500+
                      </p>
                    </div>
                  </label>
                </div>
              </fieldset>

              <div class="grid gap-4 md:grid-cols-2">
                <div class="space-y-2">
                  <label for="first_name" class="text-sm font-medium text-neutral-200"
                    >First name</label
                  >
                  <input
                    type="text"
                    id="first_name"
                    name="first_name"
                    required
                    class={GLASS_INPUT_CLASS}
                  />
                </div>
                <div class="space-y-2">
                  <label for="last_name" class="text-sm font-medium text-neutral-200"
                    >Last name</label
                  >
                  <input
                    type="text"
                    id="last_name"
                    name="last_name"
                    required
                    class={GLASS_INPUT_CLASS}
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label for="email" class="text-sm font-medium text-neutral-200"
                  >Email</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class={GLASS_INPUT_CLASS}
                />
              </div>

              <div class="space-y-2">
                <label for="company" class="text-sm font-medium text-neutral-200"
                  >Company <span class="text-neutral-500">(optional)</span></label
                >
                <input
                  type="text"
                  id="company"
                  name="company"
                  class={GLASS_INPUT_CLASS}
                />
              </div>

              <div class="space-y-2">
                <label for="budget" class="text-sm font-medium text-neutral-200"
                  >Budget range</label
                >
                <select id="budget" name="budget" required class={GLASS_INPUT_CLASS}>
                  <option value="">Select a range</option>
                  <option value="under-1k">Under $1,000</option>
                  <option value="1k-5k">$1,000 – $5,000</option>
                  <option value="5k-15k">$5,000 – $15,000</option>
                  <option value="15k-25k">$15,000 – $25,000</option>
                  <option value="25k-plus">$25,000+</option>
                </select>
              </div>

              <div class="space-y-2">
                <label for="timeline" class="text-sm font-medium text-neutral-200"
                  >Target timeline</label
                >
                <select id="timeline" name="timeline" required class={GLASS_INPUT_CLASS}>
                  <option value="">Select timeline</option>
                  <option value="1-month">Within 1 month</option>
                  <option value="2-3-months">2–3 months</option>
                  <option value="3-6-months">3–6 months</option>
                  <option value="flexible">Flexible</option>
                </select>
              </div>

              <div class="space-y-2">
                <label for="description" class="text-sm font-medium text-neutral-200"
                  >Project description</label
                >
                <textarea
                  id="description"
                  name="description"
                  rows="5"
                  required
                  placeholder="What problem are you solving? Who uses it today?"
                  class={`${GLASS_INPUT_CLASS} resize-y`}></textarea>
              </div>

              <button type="submit" class={`${GLASS_BTN_PRIMARY_CLASS} w-full`}>
                Send inquiry
              </button>
            </form>
          </div>

          <aside class="lg:sticky lg:top-24" aria-labelledby="our-team-heading">
            <div class={`${GLASS_CARD_CLASS} p-8`}>
              <h2
                id="our-team-heading"
                class="text-sm font-bold uppercase tracking-widest text-neutral-200"
              >
                Our Team
              </h2>

              <ul class="mt-6 space-y-8">
                {
                  TEAM.map((member) => (
                    <li>
                      <article class="flex gap-4">
                        {member.imagePath ? (
                          <Image
                            src={profileImage}
                            alt={member.imageAlt ?? member.name}
                            class="h-16 w-16 shrink-0 rounded-lg object-cover ring-2 ring-neutral-700/80 pixelated"
                            width={128}
                            height={128}
                            loading="lazy"
                            decoding="async"
                          />
                        ) : null}
                        <div class="min-w-0">
                          <h3 class="font-semibold text-neutral-100">{member.name}</h3>
                          <p class="mt-1 text-sm text-neutral-400">{member.role}</p>
                          <p class="mt-3 text-sm leading-relaxed text-neutral-300">
                            {member.bio}
                          </p>
                        </div>
                      </article>
                    </li>
                  ))
                }
              </ul>

              <div class="mt-8 border-t border-neutral-700/60 pt-8">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                  What to expect
                </h3>
                <ul class="mt-4 space-y-4 text-sm text-neutral-300">
                  {
                    PARTNER_EXPECTATIONS.map((item) => (
                      <li class="flex gap-3">
                        <span class="text-neutral-500" aria-hidden="true">✓</span>
                        {item}
                      </li>
                    ))
                  }
                </ul>
                <p class="mt-6 text-sm text-neutral-500">
                  Typical response: 24–72 hours
                </p>
              </div>
            </div>
          </aside>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .partner-page {
    background-image: url(/pattern.svg);
    background-position: top center;
    background-repeat: no-repeat;
  }

  html {
    scroll-behavior: smooth;
  }

  .form-submitting {
    opacity: 0.7;
    pointer-events: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.querySelector(
      'form[name="partner-inquiry"]'
    ) as HTMLFormElement | null;
    const submitBtn = form?.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;

    if (!form || !submitBtn) return;

    form.addEventListener("submit", (e) => {
      const requiredFields = form.querySelectorAll("[required]");
      let allValid = true;

      requiredFields.forEach((field) => {
        const input = field as
          | HTMLInputElement
          | HTMLTextAreaElement
          | HTMLSelectElement;
        if (!input.value.trim()) {
          input.style.borderColor = "#ef4444";
          allValid = false;
        } else {
          input.style.borderColor = "";
        }
      });

      const projectType = form.querySelector(
        'input[name="project_type"]:checked'
      );
      if (!projectType) {
        e.preventDefault();
        alert("Please select a project type.");
        return;
      }

      if (!allValid) {
        e.preventDefault();
        alert("Please fill in all required fields.");
        return;
      }

      form.classList.add("form-submitting");
      submitBtn.textContent = "Sending…";
    });

    form.querySelectorAll("input, textarea, select").forEach((input) => {
      input.addEventListener("input", () => {
        const el = input as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
        if (el.value.trim()) el.style.borderColor = "";
      });
    });
  });
</script>
