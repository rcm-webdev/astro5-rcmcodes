---
import SocialLinks from "../components/SocialLinks.astro";
import Experience from "../components/experience/index.astro";
import Project from "../components/projects/index.astro";
import { EXPERIENCE } from "../data/experience";
import { PROJECTS } from "../data/projects";
import { SKILLS } from "../data/skills";
import { EDUCATION } from "../data/education";
import { CERTIFICATIONS } from "../data/certifications";
import Layout from "../layouts/Layout.astro";
import LogoWall from "../components/logoWall.astro";
import { Image } from "astro:assets";
import CalButton from "../components/CalButton";
import { PROFILE } from "../data/profile";
import profileImage from "../../public/profile.png";
---

<Layout 
  title={`Roberto Murillo - ${PROFILE.title} | RCM CODES`}
  seo={{
    description: `${PROFILE.title} | ${PROFILE.focus}. Roberto Murillo builds health tech software, clinical workflow tools, and AI-native platforms in Spokane, WA.`,
    canonical: "https://rcmcodes.com/",
    openGraph: {
      title: `Roberto Murillo - ${PROFILE.title}`,
      description: `${PROFILE.title} | ${PROFILE.focus}`,
      type: "profile"
    },
    structuredData: {
      "@context": "https://schema.org",
      "@type": ["Person", "ProfessionalService"],
      "name": "Roberto Murillo",
      "alternateName": "rcmcodes",
      "description": PROFILE.intro,
      "url": "https://rcmcodes.com",
      "image": `https://rcmcodes.com${PROFILE.imagePath}`,
      "sameAs": [
        "https://www.linkedin.com/in/rcmcodes/",
        "https://github.com/rcm-webdev"
      ],
      "jobTitle": PROFILE.title,
      "worksFor": {
        "@type": "Organization",
        "name": "Twin Rocks Software Studio"
      },
      "knowsAbout": [
        "TypeScript",
        "React",
        "Next.js",
        "Astro",
        "Node.js",
        "Python",
        "PostgreSQL",
        "Prisma",
        "Health Tech",
        "Clinical Workflows",
        "AI-Native Development",
        "Internal Tooling"
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": PROFILE.title,
        "occupationLocation": {
          "@type": "Place",
          "name": "Spokane, WA"
        },
        "skills": [
          "Full Stack Web Development",
          "Internal Tooling",
          "Workflow Automation",
          "API Design",
          "Schema Design"
        ]
      },
      "email": "rcmcodes@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Spokane",
        "addressRegion": "WA"
      }
    }
  }}
>
  <div class="relative hero z-10">
    <div
      class="mx-auto min-h-screen max-w-screen-2xl px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24 lg:py-0"
    >
      <div class="lg:flex lg:justify-between lg:gap-4">
        <header
          class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24"
        >
          <div class="flex flex-col items-center text-center gap-6">
            <!-- Profile Image -->
              <Image
              src={profileImage}
              alt={PROFILE.imageAlt}
              class="w-40 h-40 object-cover rounded-xl ring-2 ring-neutral-700/80 pixelated"
              width={160}
              height={160}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            
            <!-- Name and Titles -->
            <div class="flex flex-col items-center gap-2 max-w-sm">
              <p class="text-sm lg:text-lg font-medium text-neutral-200/60 py-1 px-3 rounded-full bg-neutral-400/10">Hi, I'm Roberto Murillo</p>
              <a
                href="/"
                class="block font-medium tracking-tight text-center"
              >
                <h2 class="text-3xl lg:text-4xl">{PROFILE.title}</h2>
                <p class="mt-2 text-sm lg:text-base font-normal text-neutral-400 leading-relaxed">
                  {PROFILE.focus}
                </p>
              </a>
            </div>

            <!-- Call to Action Buttons -->
            <div class="flex flex-row flex-wrap justify-center gap-3 items-center">
              <a
                data-ccursor
                href="mailto:rcmcodes@gmail.com?subject=Hey 👋 I'm interested in hiring you, let's talk!"
                class="inline-flex transition-all border-neutral-700 hover:border-opacity-0 border-opacity-50 shadow rounded-md border backdrop-blur-xl bg-neutral-400/10 px-3 py-2.5 items-center text-white font-semibold group p-2 text-sm gap-x-2"
              >
                <span>Hire me</span>
                <span
                  class="w-2 h-2 rounded-full bg-green-400 duration-1000 animate-pulse"
                >
                </span>
              </a>

              <CalButton client:load />
            </div>
            
            <!-- Logo Wall -->
            <div class="mt-4 w-full max-w-sm">
              <LogoWall />
            </div>

          </div>
        </header>

        <main id="content" class="pt-24 lg:w-1/2 lg:py-24">
          <!-- Introduction Section -->
          <section
            id="introduction"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-4 lg:scroll-mt-24 "
            aria-label="Introduction"
          >
          <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Introduction
              </h2>
            </div>
            <div>
              <div>
                <p class="text-lg font-medium leading-relaxed">
                  {PROFILE.intro}
                </p>
              </div>
          </section>

          <!-- About Me Section -->
          <section
            id="about"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-4 lg:scroll-mt-18"
            aria-label="About me"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                About
              </h2>
            </div>
            <div>
              <div class="mb-4 space-y-4">
                
                <p>
                  After earning my B.S. in Biochemistry from Whitworth University, I started in healthcare as a medical scribe at Idaho Urology Institute, where I built the clinic's first structured training system. That work led me into clinical operations at Spokane Eye Clinic, where I ship production tools like TransposeRx (an LMS for technician onboarding) and Kit Tracker (QR-based inventory for procedure supplies).
                </p>
                <p>
                  As Technical Lead at Twin Rocks Software Studio, I partner with small and medium businesses to replace manual spreadsheets, paper checklists, and word-of-mouth-only workflows with centralized platforms, from lead-generation sites to quoting systems and field audit tools.
                </p>
                <p>
                  I'm open to roles where software directly improves how teams operate day to day.
                </p>
              </div>
            </div>
          </section>

          <!-- Skills -->
          <section
            id="skills"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-4 lg:scroll-mt-24"
            aria-label="Skills"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Skills
              </h2>
            </div>
            <div class="space-y-6">
              {
                SKILLS.map((group) => (
                  <div>
                    <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-400 mb-2">
                      {group.category}
                    </h3>
                    <ul class="flex flex-wrap gap-2" aria-label={group.category}>
                      {group.items.map((skill) => (
                        <li>
                          <div class="flex items-center backdrop-blur-sm rounded-full border border-neutral-700 border-opacity-50 shadow bg-neutral-400/10 px-3 py-1 text-xs font-medium leading-5 text-neutral-300">
                            {skill}
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))
              }
            </div>
          </section>

          <!-- Experience -->
          <section
            id="experience"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-4 lg:scroll-mt-24"
            aria-label="Work experience"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Experience
              </h2>
            </div><div>
              <ol class="group/list space-y-12">
                {EXPERIENCE.map((experience) => <Experience {...experience} />)}
              </ol>
            </div>
          </section>

          <!-- Featured Projects -->
          <section
            id="applications"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
            aria-label="Web Applications"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Featured Projects
              </h2>
            </div>
            <div>
              <ol class="group/list space-y-12">
                {PROJECTS.map((project) => <Project {...project} />)}
              </ol>
            </div>
          </section>

          <!-- Education -->
          <section
            id="education"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-4 lg:scroll-mt-24"
            aria-label="Education"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Education
              </h2>
            </div>
            <ol class="space-y-6">
              {
                EDUCATION.map((entry) => (
                  <li>
                    <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                      {entry.dates}
                    </p>
                    <h3 class="mt-1 font-medium text-neutral-200">
                      <a
                        href={entry.schoolUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="hover:text-neutral-300"
                      >
                        {entry.school}
                      </a>
                      <span class="text-neutral-400"> · {entry.degree}</span>
                    </h3>
                  </li>
                ))
              }
            </ol>
          </section>

          <!-- Certifications -->
          <section
            id="certifications"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
            aria-label="Certifications"
          >
            <div
              class="section-header sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Certifications
              </h2>
            </div>
            <ol class="space-y-6">
              {
                CERTIFICATIONS.map((cert) => (
                  <li>
                    <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                      {cert.dates}
                    </p>
                    <h3 class="mt-1 font-medium text-neutral-200">
                      <a
                        href={cert.credentialUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="hover:text-neutral-300"
                      >
                        {cert.name}
                      </a>
                      <span class="text-neutral-400"> · {cert.issuer}</span>
                    </h3>
                  </li>
                ))
              }
            </ol>
          </section>
          <footer class="max-w-md pb-16 text-sm text-neutral-500 sm:pb-0">
            <p>
              Designed in
              <a
                href="https://www.figma.com/"
                class="font-medium text-neutral-400 hover:text-red-300 focus-visible:text-red-300 hover:underline"
                target="_blank"
                rel="noreferrer">Figma</a
              >
              and coded in
              <a
                href="https://code.visualstudio.com/"
                class="font-medium text-neutral-400 hover:text-red-300 focus-visible:text-red-300 hover:underline"
                target="_blank"
                rel="noreferrer">Visual Studio Code</a
              >
            </p>
          </footer>
        </main>
      </div>
    </div>
  </div>

  <footer class="relative z-10 border-t border-neutral-800/60 text-center py-10 px-6">
    <SocialLinks />
    <p class="mt-6 text-xs text-neutral-500">
      {new Date().getFullYear()}. All rights reserved.
    </p>
  </footer>
</Layout>

<style scoped>
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  .hero {
    background-image: url(/pattern.svg);
    background-position: top center;
    background-repeat: no-repeat;
    overflow-y: visible;
    overflow-x: clip;
  }

  .shiny-sec {
    background: linear-gradient(135deg, #a476ff 25%, #eee5ff 50%, #a476ff 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }

  @keyframes shine {
    0% {
      background-position: 100% 50%;
    }
    30%,
    70% {
      background-position: 0% 50%;
    }
  }

  /* Fix for mobile sticky headers stacking issue */
  @media (max-width: 1023px) {
    .section-header {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(23, 23, 23, 0.8);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    /* Ensure each section header has a unique z-index to prevent stacking */
    #introduction .section-header {
      z-index: 15;
    }
    
    #about .section-header {
      z-index: 14;
    }
    
    #experience .section-header {
      z-index: 13;
    }
    
    #skills .section-header {
      z-index: 12;
    }

    #applications .section-header {
      z-index: 11;
    }

    #education .section-header {
      z-index: 10;
    }

    #certifications .section-header {
      z-index: 9;
    }
  }

  /*
  .hero {
    animation: fadeIn 3s;
  }
   */
</style>
