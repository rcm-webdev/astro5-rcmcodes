---
import SocialLinks from "../components/SocialLinks.astro";
import { EXPERIENCE } from "../data/experience";
import { PROJECTS } from "../data/projects";
import { CERTIFICATIONS } from "../data/certifications";
import Layout from "../layouts/Layout.astro";
import SkillHub from "../components/SkillHub.astro";
import CalButton from "../components/CalButton";
import IconLinks from "../components/icons/links.astro";
import { HERO_CTA_CLASS, NAV_COPY, TEXT_LINK_CLASS } from "../data/contact";
import { PROFILE } from "../data/profile";
import { BRAND } from "../data/brand";
import { ExperienceSection } from "../components/experience/ExperienceSection";

const transposeRxProject = PROJECTS.find((p) => p.title === "TransposeRx");
const kitTrackerProject = PROJECTS.find((p) => p.title === "Kit Tracker");

const titleMatch = PROFILE.title.match(/^(.+)\s+(\S+)$/);
const titleLead = titleMatch?.[1] ?? PROFILE.title;
const titleAccent = titleMatch?.[2];

/** Mobile section labels — static (not sticky) to avoid sticky handoff jitter */
const SECTION_HEADER_CLASS =
  "section-header -mx-6 mb-4 px-6 py-3 md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0";
---

<Layout 
  title={`${PROFILE.displayName} - ${PROFILE.title} | RCM CODES`}
  seo={{
    description: `${PROFILE.title} | ${PROFILE.focus}. ${PROFILE.displayName} builds health tech software, clinical workflow tools, and AI-native platforms in Spokane, WA.`,
    canonical: "https://rcmcodes.com/",
    openGraph: {
      title: `${PROFILE.displayName} - ${PROFILE.title}`,
      description: `${PROFILE.title} | ${PROFILE.focus}`,
      type: "profile"
    },
    structuredData: {
      "@context": "https://schema.org",
      "@type": ["Person", "ProfessionalService"],
      "name": PROFILE.displayName,
      "alternateName": [PROFILE.alternateName, "rcmcodes"],
      "description": PROFILE.intro,
      "url": "https://rcmcodes.com",
      "image": `https://rcmcodes.com${PROFILE.imagePath}`,
      "sameAs": [
        "https://www.linkedin.com/in/rcmcodes/",
        "https://github.com/rcm-webdev"
      ],
      "jobTitle": PROFILE.title,
      "worksFor": {
        "@type": "Organization",
        "name": "Twin Rocks Software Studio"
      },
      "knowsAbout": [
        "TypeScript",
        "React",
        "Next.js",
        "Astro",
        "Node.js",
        "Python",
        "PostgreSQL",
        "Prisma",
        "Health Tech",
        "Clinical Workflows",
        "AI-Native Development",
        "Internal Tooling"
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": PROFILE.title,
        "occupationLocation": {
          "@type": "Place",
          "name": "Spokane, WA"
        },
        "skills": [
          "Full Stack Web Development",
          "Internal Tooling",
          "Workflow Automation",
          "API Design",
          "Schema Design"
        ]
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Spokane",
        "addressRegion": "WA"
      }
    }
  }}
>
  <div class="relative hero z-10">
    <div
      class="mx-auto min-h-screen max-w-screen-2xl px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24 lg:py-0"
    >
      <div class="lg:flex lg:justify-between lg:gap-4">
        <header
          class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24"
        >
          <div class="flex flex-col items-center text-center gap-6">
            <div class="flex flex-col items-center gap-3">
              <img
                src="/sunglasses_dev.svg"
                alt="Pixel art avatar with speech bubble Hi I'm Roberto"
                class="w-full max-w-[16rem] pixelated sm:max-w-[18rem]"
                width={1024}
                height={1024}
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />

              <!-- Name and Titles -->
              <div class="flex flex-col items-center gap-2 max-w-sm">
              <a
                href="/"
                class="block font-medium tracking-tight text-center"
              >
                <h2 class="text-3xl lg:text-4xl">
                  <span class="hero-title-lead">{titleLead}</span>
                  {titleAccent && (
                    <>
                      {" "}
                      <span class="hero-title-accent">{titleAccent}</span>
                    </>
                  )}
                </h2>
                <p class="mt-2 text-sm lg:text-base font-normal text-neutral-400 leading-relaxed">
                  {PROFILE.focus}
                </p>
              </a>
              </div>
            </div>

            <!-- Call to Action Buttons -->
            <div
              class="flex flex-row flex-wrap justify-center gap-3 items-center"
              role="group"
              aria-label="Contact options"
            >
              <CalButton client:load />

              <a
                data-ccursor
                href="/links/"
                class={HERO_CTA_CLASS}
              >
                <IconLinks />
                <span>{NAV_COPY.allLinks} →</span>
              </a>
            </div>

            <!-- Skill hub -->
            <div class="mt-4 w-full max-w-sm">
              <SkillHub />
            </div>

          </div>
        </header>

        <main id="content" class="pt-24 lg:w-1/2 lg:py-24">
          <!-- Introduction Section -->
          <section
            id="introduction"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-10 lg:scroll-mt-24 "
            aria-label="Introduction"
          >
          <div
              class={SECTION_HEADER_CLASS}
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Introduction
              </h2>
            </div>
            <div class="lg:rounded-2xl lg:border lg:border-neutral-800/70 lg:bg-neutral-950/20 lg:p-6 lg:shadow-sm lg:shadow-black/20">
              <p class="text-lg font-medium leading-relaxed">
                {PROFILE.intro}
              </p>
            </div>
          </section>

          <!-- About Me Section -->
          <section
            id="about"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-10 lg:scroll-mt-18"
            aria-label="About me"
          >
            <div
              class={SECTION_HEADER_CLASS}
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                About
              </h2>
            </div>
            <div class="lg:rounded-2xl lg:border lg:border-neutral-800/70 lg:bg-neutral-950/20 lg:p-6 lg:shadow-sm lg:shadow-black/20">
              <div class="space-y-4">
                
                <p class="text-lg font-medium leading-relaxed">
                  After earning my B.S. in Biochemistry from Whitworth University, I started in healthcare as a medical scribe at Idaho Urology Institute, where I built the clinic's first structured training system. That work led me into clinical operations at Spokane Eye Clinic, where I ship production tools like{" "}
                  <a
                    href={transposeRxProject!.projectUrl}
                    class={TEXT_LINK_CLASS}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="TransposeRx (opens in a new tab)"
                  >
                    TransposeRx
                  </a>{" "}
                  (an LMS for technician onboarding) and{" "}
                  <a
                    href={kitTrackerProject!.projectUrl}
                    class={TEXT_LINK_CLASS}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Kit Tracker (opens in a new tab)"
                  >
                    Kit Tracker
                  </a>{" "}
                  (QR-based inventory for procedure supplies).
                </p>
                <p class="text-lg font-medium leading-relaxed">
                  As Technical Lead at{" "}
                  <a
                    href="/partner/"
                    class={TEXT_LINK_CLASS}
                    aria-label={BRAND.studioName}
                  >
                    {BRAND.studioName}
                  </a>
                  , I partner with small and medium businesses to replace manual spreadsheets, paper checklists, and word-of-mouth-only workflows with centralized platforms, from lead-generation sites to quoting systems and field audit tools.
                </p>
                <p class="text-lg font-medium leading-relaxed">
                  I'm open to roles where software directly improves how teams operate day to day.
                </p>
              </div>
            </div>
          </section>

          <!-- Experience -->
          <section
            id="experience"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-10 lg:scroll-mt-24"
            aria-label="Work experience"
          >
            <div
              class={SECTION_HEADER_CLASS}
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Experience
              </h2>
            </div>
            <ExperienceSection client:load experiences={EXPERIENCE} projects={PROJECTS} />
          </section>

          <!-- Certifications -->
          <section
            id="certifications"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
            aria-label="Certifications"
          >
            <div
              class={SECTION_HEADER_CLASS}
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only"
              >
                Certifications
              </h2>
            </div>
            <div class="lg:rounded-2xl lg:border lg:border-neutral-800/70 lg:bg-neutral-950/20 lg:p-6 lg:shadow-sm lg:shadow-black/20">
              <ol class="space-y-6">
                {
                  CERTIFICATIONS.map((cert) => (
                    <li>
                      <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                        {cert.dates}
                      </p>
                      <h3 class="mt-1 font-medium text-neutral-200">
                        <a
                          href={cert.credentialUrl}
                          target="_blank"
                          rel="noreferrer"
                          class="hover:text-neutral-300"
                        >
                          {cert.name}
                        </a>
                        <span class="text-neutral-400"> · {cert.issuer}</span>
                      </h3>
                    </li>
                  ))
                }
              </ol>
            </div>
          </section>
          <footer class="max-w-md pb-16 text-sm text-neutral-500 sm:pb-0">
            <p>
              Designed in
              <a
                href="https://www.figma.com/"
                class="font-medium text-neutral-400 hover:text-red-300 focus-visible:text-red-300 hover:underline"
                target="_blank"
                rel="noreferrer">Figma</a
              >
              and coded in
              <a
                href="https://code.visualstudio.com/"
                class="font-medium text-neutral-400 hover:text-red-300 focus-visible:text-red-300 hover:underline"
                target="_blank"
                rel="noreferrer">Visual Studio Code</a
              >
            </p>
          </footer>
        </main>
      </div>
    </div>
  </div>

  <footer class="relative z-10 border-t border-neutral-800/60 text-center py-10 px-6">
    <SocialLinks />
    <p class="mt-6 text-xs text-neutral-500">
      {new Date().getFullYear()}. All rights reserved.
    </p>
  </footer>

</Layout>

<style scoped>
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  .hero {
    background-image: url(/pattern.svg);
    background-position: top center;
    background-repeat: no-repeat;
  }

  .shiny-sec {
    background: linear-gradient(135deg, #a476ff 25%, #eee5ff 50%, #a476ff 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }

  @keyframes shine {
    0% {
      background-position: 100% 50%;
    }
    30%,
    70% {
      background-position: 0% 50%;
    }
  }

  /* Static section labels on mobile/tablet — avoids sticky handoff bounce */
  @media (max-width: 1023px) {
    .section-header {
      background: rgb(23 23 23 / 0.92);
      border-bottom: 1px solid rgb(255 255 255 / 0.1);
    }
  }

  /*
  .hero {
    animation: fadeIn 3s;
  }
   */
</style>
