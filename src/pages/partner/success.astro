---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BrandLogo from "../../components/BrandLogo.astro";
import { BRAND } from "../../data/brand";
import { GLASS_CARD_CLASS, GLASS_BTN_CLASS, GLASS_BTN_PRIMARY_CLASS } from "../../data/contact";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Partner", href: "/partner" },
  { label: "Success" },
];
---

<Layout
  title={`Thank you | ${BRAND.studioName}`}
  seo={{
    description:
      "Your project inquiry to Twin Rocks Software Studio was received. Roberto will respond within 24–72 hours.",
    canonical: "https://rcmcodes.com/partner/success",
    noindex: true,
    openGraph: {
      title: "Inquiry received: Twin Rocks Software Studio",
      description: "Thank you for reaching out. We'll be in touch shortly.",
    },
  }}
>
  <div class="relative z-10">
    <div
      class="mx-auto min-h-screen max-w-screen-2xl px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24"
    >
      <Breadcrumbs items={breadcrumbItems} />

      <section class="flex min-h-[70vh] items-center justify-center py-16">
        <div class="mx-auto max-w-2xl text-center">
          <div
            class="flex flex-col items-center gap-6 sm:flex-row sm:justify-center sm:gap-5"
          >
            <BrandLogo
              variant="success"
              class="ring-2 ring-neutral-700/80"
              loading="eager"
            />
            <div
              class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-neutral-700/60 bg-neutral-400/10 backdrop-blur-xl"
              aria-hidden="true"
            >
            <svg
              class="h-7 w-7 text-neutral-200"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            </div>
          </div>

          <h1 class="mt-8 text-4xl font-bold tracking-tight text-neutral-100 md:text-5xl">
            Message received
          </h1>
          <p class="mt-4 text-lg leading-relaxed text-neutral-300">
            Thanks for reaching out to {BRAND.studioName}. Your inquiry is in the
            queue. We'll review it and respond within 24–72 hours.
          </p>

          <div class={`${GLASS_CARD_CLASS} mt-10 p-8 text-left`}>
            <h2 class="text-center text-lg font-semibold text-neutral-100">
              What happens next
            </h2>
            <ol class="mt-6 space-y-5">
              {
                [
                  {
                    step: "1",
                    title: "Review",
                    body: "We'll read your project details and confirm whether we're a good fit.",
                  },
                  {
                    step: "2",
                    title: "Discovery call",
                    body: "A short conversation to clarify goals, constraints, and timeline.",
                  },
                  {
                    step: "3",
                    title: "Proposal",
                    body: "A written scope with deliverables, schedule, and transparent pricing.",
                  },
                ].map((item) => (
                  <li class="flex gap-4">
                    <span
                      class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-neutral-700/60 bg-neutral-400/10 text-sm font-semibold text-neutral-300"
                    >
                      {item.step}
                    </span>
                    <div>
                      <h3 class="font-medium text-neutral-100">{item.title}</h3>
                      <p class="mt-1 text-sm text-neutral-400">{item.body}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>

          <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
            <a href="/" class={GLASS_BTN_PRIMARY_CLASS}>Back to homepage</a>
            <a href="/partner" class={GLASS_BTN_CLASS}>Submit another inquiry</a>
          </div>

          <p class="mt-8 text-sm text-neutral-500">
            Urgent? <a
              href="mailto:rcmcodes@gmail.com"
              class="text-neutral-300 underline-offset-2 hover:text-neutral-100 hover:underline"
              >rcmcodes@gmail.com</a
            >
          </p>
        </div>
      </section>
    </div>
  </div>
</Layout>
