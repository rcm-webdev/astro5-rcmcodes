---
import Component from "./Component.astro";
import { SOCIALS } from "../data/socials";
---

{
  SOCIALS.length > 0 && (
    <ul
      class="flex flex-wrap items-center justify-center gap-3"
      aria-label="Social media"
    >
      {SOCIALS.map((social) => (
        <li data-ccursor>
          <a
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-neutral-700/60 bg-neutral-400/10 text-neutral-400 shadow backdrop-blur-xl transition-all hover:border-neutral-500 hover:bg-neutral-400/15 hover:text-neutral-100"
            href={social.url}
            target={social.url.startsWith("/") ? undefined : "_blank"}
            rel={social.url.startsWith("/") ? undefined : "noreferrer noopener"}
            aria-label={
              social.url.startsWith("/")
                ? social.name
                : `${social.name} (opens in a new tab)`
            }
          >
            <span class="sr-only">{social.name}</span>
            {<Component component={social.icon} />}
          </a>
        </li>
      ))}
    </ul>
  )
}
