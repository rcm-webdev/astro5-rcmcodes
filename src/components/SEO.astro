---
import { PROFILE } from "../data/profile";

export interface SEOProps {
  title: string;
  description: string;
  canonical?: string;
  openGraph?: {
    title?: string;
    description?: string;
    image?: string;
    imageAlt?: string;
    type?: string;
  };
  twitter?: {
    card?: string;
    title?: string;
    description?: string;
    image?: string;
    imageAlt?: string;
  };
  structuredData?: any;
  noindex?: boolean;
  keywords?: string;
}

interface Props extends SEOProps {}

const {
  title,
  description,
  canonical = "https://rcmcodes.com/",
  openGraph = {},
  twitter = {},
  structuredData,
  noindex = false,
  keywords = `${PROFILE.displayName}, ${PROFILE.alternateName}, Full Stack Software Engineer, Spokane, React, TypeScript, Next.js, Astro, Node.js, Python, Prisma, Internal Tooling, rcmcodes`
} = Astro.props;

// Default values for Open Graph
const ogTitle = openGraph.title || title;
const ogDescription = openGraph.description || description;
const ogImage = openGraph.image || "https://rcmcodes.com/demo.png";
const ogImageAlt = openGraph.imageAlt || `${PROFILE.displayName} - Full Stack Software Engineer`;
const ogType = openGraph.type || "website";

// Default values for Twitter
const twitterCard = twitter.card || "summary_large_image";
const twitterTitle = twitter.title || title;
const twitterDescription = twitter.description || description;
const twitterImage = twitter.image || "https://rcmcodes.com/demo.png";
const twitterImageAlt = twitter.imageAlt || `${PROFILE.displayName} - Full Stack Software Engineer`;

// Default structured data for person/organization
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": PROFILE.displayName,
  "alternateName": [PROFILE.alternateName, "rcmcodes"],
  "description": "Full Stack Engineer | Health Tech · Clinical Workflows · AI-Native Development",
  "url": "https://rcmcodes.com",
  "image": "https://rcmcodes.com/profile.png",
  "sameAs": [
    "https://www.linkedin.com/in/rcmcodes/",
    "https://github.com/rcm-webdev"
  ],
  "jobTitle": "Full Stack Engineer",
  "worksFor": {
    "@type": "Organization",
    "name": "Twin Rocks Software Studio"
  },
  "knowsAbout": [
    "JavaScript",
    "TypeScript",
    "React",
    "Node.js",
    "Python",
    "Next.js",
    "Astro",
    "Prisma",
    "Workflow Automation",
    "Internal Tooling"
  ],
  "email": "rcmcodes@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Spokane",
    "addressRegion": "WA"
  }
};

const finalStructuredData = structuredData || defaultStructuredData;
---

<!-- Basic Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={PROFILE.displayName} />
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
<link rel="canonical" href={canonical} />

<!-- Open Graph Meta Tags -->
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:site_name" content="RCM CODES" />

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={twitterTitle} />
<meta name="twitter:description" content={twitterDescription} />
<meta name="twitter:image" content={twitterImage} />
<meta name="twitter:image:alt" content={twitterImageAlt} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(finalStructuredData)} />

<!-- Additional SEO Meta Tags -->
<meta name="theme-color" content="#000000" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<!-- Preconnect to external domains -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /> 